OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# =============================
# Provider order for failover
# =============================
# Example: openai,openrouter,anthropic,google
PRIORITIZER_PROVIDER_ORDER=openai,openrouter,anthropic,google

# =============================
# Model override per provider (optional)
# =============================
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GOOGLE_MODEL=gemini-1.5-flash

# =============================
# OpenRouter optional headers
# =============================
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Vinschool-Notification-Agent

# =============================
# Prompt override (optional)
# =============================
# If set, this file path overrides nodes/prompts/prioritizer_system_prompt.md
PRIORITIZER_SYSTEM_PROMPT_FILE=
